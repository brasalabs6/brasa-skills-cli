{
  "name": "@brasalabs/skills",
  "version": "0.2.0",
  "private": false,
  "type": "module",
  "description": "BrasaLabs CLI for installing and updating Codex and Agents skills from BrasaLabs skill repositories.",
  "bin": {
    "brasa-skills": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc && node scripts/copy-assets.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests scripts",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "pack:dry-run": "pnpm build && npm pack --dry-run",
    "pack:check": "node scripts/check-package-artifact.mjs",
    "check:br-integration": "node scripts/check-br-integration-artifact.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "check:release": "pnpm check && npm pack --dry-run && pnpm pack:check && pnpm release:dry-run",
    "release:pack": "node scripts/release-package.mjs pack",
    "release:dry-run": "node scripts/release-package.mjs dry-run",
    "release:publish": "node scripts/release-package.mjs publish"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "commander": "^14.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^24.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
