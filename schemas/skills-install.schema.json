{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/brasalabs6/brasa-skills-cli/main/schemas/skills-install.schema.json",
  "title": "Brasa Skills Install Plan",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "skills"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "defaults": { "$ref": "#/$defs/defaults" },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/installItem" }
    }
  },
  "$defs": {
    "target": { "enum": ["codex", "agents"] },
    "scope": { "enum": ["project", "global"] },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": { "$ref": "#/$defs/target" },
        "scope": { "$ref": "#/$defs/scope" },
        "ref": { "type": "string", "minLength": 1 }
      }
    },
    "installItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo"],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "skill": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$",
          "maxLength": 64
        },
        "target": { "$ref": "#/$defs/target" },
        "scope": { "$ref": "#/$defs/scope" },
        "ref": { "type": "string", "minLength": 1 }
      }
    }
  }
}
