{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/brasalabs6/brasa-skills-cli/main/schemas/skills-marketplace.schema.json",
  "title": "Brasa Skills Marketplace",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "name", "repositories"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$"
    },
    "repositories": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/repository" }
    }
  },
  "$defs": {
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "skills"],
      "properties": {
        "repo": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "defaultRef": {
          "type": "string",
          "minLength": 1,
          "default": "main"
        },
        "description": { "type": "string" },
        "skills": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/skill" }
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "path"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$",
          "maxLength": 64
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "not": {
            "anyOf": [
              { "pattern": "^/" },
              { "pattern": "(^|/)\\.\\.(/|$)" }
            ]
          }
        },
        "description": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$|^[a-z0-9]$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
